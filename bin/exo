#!/usr/bin/env bash
# exo — Aitower CLI client.
# Thin wrapper that resolves the project root and runs the CLI entry point.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_DIR/cli"
exec bun run src/main.ts "$@"
